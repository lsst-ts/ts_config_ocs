{
    "name": "BLOCK-T389",
    "program": "BLOCK-T389",
    "constraints": [],
    "configuration_schema": "$schema: http://json-schema.org/draft-07/schema#\ntitle: BLOCK-T389 Configuration\ndescription: Configuration for the BLOCK-T389 Giant Donut Characterization Test WET-005.\ntype: object\nproperties:\n  ra:\n    description: Right Ascension.\n    type: number\n    default: 0\n  dec:\n    description: Declination.\n    type: number\n    default: 0\n",
    "scripts": [
        {
            "name": "maintel/enable_mtcs.py",
            "standard": true,
            "parameters": {}
        },
        {
            "name": "maintel/track_target.py",
            "standard": true,
            "parameters": {
                "slew_icrs": {
                    "ra": "$ra", 
                    "dec": "$dec"
                }
            }
        },
        {
            "name": "maintel/take_aos_sequence_lsstcam.py",
            "standard": true,
            "parameters": {
                "exposure_time": 60.0,
                "dz": 6000,
                "n_sequences": 2,
                "program": "$program",
                "reason": "SITCOM-1147",
                "note": "giant_donut"
            }
        },
        {
            "name": "maintel/take_image_lsstcam.py",
            "standard": true,
            "parameters": {
                "image_type": "ACQ",
                "nimages": 2,
                "exp_times": 30.0,
                "program": "$program",
                "reason": "SITCOM-1147",
                "note": "giant_donut"
            }
        },
        {
            "name": "maintel/stop_tracking.py",
            "standard": true,
            "parameters": {}
        }
    ]
}