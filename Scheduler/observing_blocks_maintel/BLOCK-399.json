{
    "name": "BLOCK-399",
    "program": "BLOCK-399",
    "constraints": [],
    "scripts": [
        {
            "name": "run_command.py",
            "standard": true,
            "parameters": {
                "component": "MTReflector",
                "command": "open"
            }
        },
        {
            "name": "maintel/make_lsstcam_calibrations.py",
            "standard": false,
            "parameters": {
                "script_mode": "BIAS_DARK",
                "n_bias": 3,
                "n_discard_bias": 1,
                "n_dark": 3,
                "n_discard_dark": 1,
                "exp_times_dark": [15, 30, 38],
                "wait_between_exposures": 30,
                "generate_calibrations": true,
                "do_verify": true
            }
        },
        {
            "name": "maintel/setup_whitelight_flats.py",
            "standard": false,
            "parameters":{
                "ignore": "$ignore"
            }
        },
        {
            "name": "maintel/take_whitelight_flats_lsstcam.py",
            "standard": false,
            "parameters": {
                "sequence_names": "$sequence_names",
                "reason": "flat",
                "program": "BLOCK-T399"
            }
        },
        {
            "name": "maintel/take_whitelight_flats_lsstcam.py",
            "standard": false,
            "parameters": {
                "sequence_names": ["ptc_daily"],
                "reason": "ptc",
                "program": "BLOCK-T399"
            }
        },
        {
            "name": "maintel/park_calibration_projector.py",
            "standard": false,
            "parameters": {
                "ignore": "$ignore"
            }
        },
        {
            "name": "run_command.py",
            "standard": true,
            "parameters": {
                "component": "MTReflector",
                "command": "close"
            }
        }

    ],
     "configuration_schema": "$schema: http://json-schema.org/draft-07/schema#\ntitle: BLOCK-399 configuration\ndescription: Configuration for BLOCK-399.\ntype: object\nproperties:\n  ignore:\n    description: Name of the CSCs we want to ignore\n    type: array\n    default: ['LinearStage:104','TunableLaser','CBP','Electrometer:101','Electrometer:102']\n  sequence_names:\n    description: List of sequence names to run for whitelight flats script.\n    type: array\n    default: ['daily']\n"
}

